      sourceRangeHint: "Cursor section in all-clients.mdx",
      configFiles: {
        user: ["~/.cursor/mcp.json"],
        project: [".cursor/mcp.json"],
      },
      easySetup: {
        supported: true,
        command: "npx ctx7 setup --cursor",
        provisionsApiKeyViaLogin: true,
        installsContext7Skill: true,
        installButtonRemoteUrl: "https://cursor.com/en/install-mcp?name=context7&config=eyJ1cmwiOiJodHRwczovL21jcC5jb250ZXh0Ny5jb20vbWNwIn0%3D",
        installButtonLocalUrl: "https://cursor.com/en/install-mcp?name=context7&config=eyJjb21tYW5kIjoibnB4IC15IEB1cHN0YXNoL2NvbnRleHQ3LW1jcCJ9",
      },
      manualSetup: {
        apiKeyRequired: true,
        configStrategy: "json-file",
        configDocsUrl: "https://docs.cursor.com/context/model-context-protocol",
