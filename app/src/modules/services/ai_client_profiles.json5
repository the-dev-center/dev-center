{
  // Profiles for AI-capable editors, coding agents, and CLIs that can use Context7.
  // The future DevCentr AI Config interface should read from this file.
  context7: {
    docsIndexUrl: "https://context7.com/docs/llms.txt",
    skillsBrowserUrl: "https://context7.com/skills/",
    allClientsDocsUrl: "https://context7.com/docs/resources/all-clients",
    allClientsSourceRawUrl: "https://raw.githubusercontent.com/upstash/context7/refs/heads/master/docs/resources/all-clients.mdx",
    allClientsSourcePlainUrl: "https://github.com/upstash/context7/blob/master/docs/resources/all-clients.mdx?plain=1",
    issueSearchUrl: "https://github.com/upstash/context7/issues?q=is%3Aissue%20state%3Aopen",
    issueNewChooseUrl: "https://github.com/upstash/context7/issues/new/choose",
    contributingGuidelinesUrl: "https://opensource.guide/",
    preferredSourceOrder: ["context7-mcp", "repo-local-docs", "web-search"],
  },

  clients: {
    "claude-code": {
      displayName: "Claude Code",
      category: "coding-agent-cli",
      launchCommand: "claude",
      context7DocsUrl: "https://context7.com/docs/clients/claude-code",
      context7ConfigUrl: "https://context7.com/docs/resources/all-clients#claude-code",
      sourcePlainUrl: "https://github.com/upstash/context7/blob/master/docs/resources/all-clients.mdx?plain=1",
      sourceRangeHint: "Claude Code section in all-clients.mdx",
      configFiles: {
        user: ["Claude Code MCP user scope"],
        project: [],
      },
      easySetup: {
        supported: true,
        command: "npx ctx7 setup --claude",
        provisionsApiKeyViaLogin: true,
        installsContext7Skill: true,
        notes: [
          "Can choose CLI or MCP mode during setup.",
          "Context7 plugin can add skills, agents, and commands.",
        ],
      },
      manualSetup: {
        apiKeyRequired: true,
        configStrategy: "command-or-remote-http",
        configDocsUrl: "https://docs.anthropic.com/en/docs/claude-code/mcp",
      },
      skillSupport: {
        type: "plugin-and-skill",
        pluginMarketplaceAddCommand: "/plugin marketplace add upstash/context7",
        pluginInstallCommand: "/plugin install context7-plugin@context7-marketplace",
      },
    },

    cursor: {
