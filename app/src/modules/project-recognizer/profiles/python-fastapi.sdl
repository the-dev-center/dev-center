// FastAPI technology profile — prefer editing this .sdl over .json5
name "FastAPI"
parent "Python"
description "Python web framework for building APIs with type hints."
anyOfFiles "**/requirements.txt" "**/pyproject.toml"
keywords "from fastapi import" "import fastapi"
manifests {
	manifest pathPattern="**/requirements.txt" format="text" {
		anyOf "fastapi"
	}
	manifest pathPattern="**/pyproject.toml" format="text" {
		anyOf "fastapi"
	}
}
